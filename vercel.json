{
  "functions": {
    "src/app/api/food-search/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders?slot=morning",
      "schedule": "0,30 * * * *"
    },
    {
      "path": "/api/cron/reminders?slot=nightly",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/coach-crm",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/ai-coach",
      "schedule": "0 14 * * *"
    }
  ]
}
