# Supabase（前端必須，Vercel 也要設定）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 正式網域（上架／法律頁面／Capacitor 殼，例：https://fitclub.hk）
NEXT_PUBLIC_SITE_URL=https://fitclub.hk
NEXT_PUBLIC_APP_URL=https://fitclub.hk
# 私隱政策聯絡電郵（App Store / Google Play 必填）
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=auchunkit1212@gmail.com
# Capacitor 原生殼載入嘅 URL（通常同 SITE_URL）
CAPACITOR_SERVER_URL=https://fitclub.hk

# 伺服器上傳 food-images Storage、寫入 meal_logs 強烈建議設定
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Web Push — 學員打卡時推播給教練（MVP，無需 App Store）
# 1) 在本機終端機生成金鑰：
#    npx web-push generate-vapid-keys
# 2) 將 Public Key 貼到 NEXT_PUBLIC_VAPID_PUBLIC_KEY（前端訂閱用）
# 3) 將 Private Key 貼到 VAPID_PRIVATE_KEY（僅伺服器，勿提交 Git）
# 4) VAPID_SUBJECT 填聯絡信箱，格式必須為 mailto:...
# 5) 同步設定 .env.local 與 Vercel → Settings → Environment Variables，然後 Redeploy
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Vercel Cron 驗證（隨機長字串，Vercel 會自動帶 Authorization header）
CRON_SECRET=

# 食物搜尋 Autocomplete — OpenRouter（/api/food-search）
OPENROUTER_API_KEY=
# 文字聯想／估算（Gemini 2.5 部分帳戶會 403，建議 deepseek）
OPENROUTER_MODEL=deepseek/deepseek-chat
# 食物搜尋 autocomplete（較快；可設 meta-llama/llama-4-scout）
OPENROUTER_AUTOCOMPLETE_MODEL=meta-llama/llama-4-scout
# 相片辨識（與 OPENROUTER_MODEL 分開；建議 Llama 4 vision）
OPENROUTER_VISION_MODEL=meta-llama/llama-4-maverick
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Nutrition Coach

# 【封印備用】/api/food-search-ai（gemini | openai | local）
GEMINI_API_KEY=
FOOD_SEARCH_AI_PROVIDER=gemini

# Phase 4 — OpenAI Vision（營養標籤 OCR + 配餐推薦）
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o-mini

# Phase 4 — Edamam 食物搜尋（https://developer.edamam.com/）
EDAMAM_APP_ID=
EDAMAM_APP_KEY=
