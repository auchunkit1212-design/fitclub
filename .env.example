# Supabase（前端必須，Vercel 也要設定）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 伺服器上傳 food-images Storage、寫入 meal_logs 強烈建議設定
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Web Push — 學員打卡時推播給教練（MVP，無需 App Store）
# 1) 在本機終端機生成金鑰：
#    npx web-push generate-vapid-keys
# 2) 將 Public Key 貼到 NEXT_PUBLIC_VAPID_PUBLIC_KEY（前端訂閱用）
# 3) 將 Private Key 貼到 VAPID_PRIVATE_KEY（僅伺服器，勿提交 Git）
# 4) VAPID_SUBJECT 填聯絡信箱，格式必須為 mailto:...
# 5) 同步設定 .env.local 與 Vercel → Settings → Environment Variables，然後 Redeploy
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Vercel Cron 驗證（隨機長字串，Vercel 會自動帶 Authorization header）
CRON_SECRET=

# 食物搜尋 Autocomplete — OpenRouter（/api/food-search）
OPENROUTER_API_KEY=
# 可選：google/gemini-2.5-flash | deepseek/deepseek-chat 等
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Nutrition Coach

# 【封印備用】/api/food-search-ai（gemini | openai | local）
GEMINI_API_KEY=
FOOD_SEARCH_AI_PROVIDER=gemini

# Phase 4 — OpenAI Vision（營養標籤 OCR + 配餐推薦）
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o-mini

# Phase 4 — Edamam 食物搜尋（https://developer.edamam.com/）
EDAMAM_APP_ID=
EDAMAM_APP_KEY=
