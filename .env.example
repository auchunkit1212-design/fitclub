# Supabase（前端必須，Vercel 也要設定）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 伺服器上傳 food-images Storage、寫入 meal_logs 強烈建議設定
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Web Push（npx web-push generate-vapid-keys）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Vercel Cron 驗證（隨機長字串，Vercel 會自動帶 Authorization header）
CRON_SECRET=

# Phase 4 — OpenAI Vision（營養標籤 OCR + 配餐推薦）
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o-mini

# Phase 4 — Edamam 食物搜尋（https://developer.edamam.com/）
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# 可選：FatSecret（需 OAuth，本專案預設用 Edamam）
# FATSECRET_CLIENT_ID=
# FATSECRET_CLIENT_SECRET=
